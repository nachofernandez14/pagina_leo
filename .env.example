# Supabase — URL del proyecto (pública)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Supabase — Anon key (pública, usada por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Contraseña para restaurar backups desde el panel de Configuración
# Obligatoria para usar la función de restauración
RESTAURAR_PASSWORD=una-contraseña-segura-aqui
