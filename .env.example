# Copie a .env.local. Valores en Supabase: Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL = "Project URL" (https://xxxxx.supabase.co) — no es ninguna clave.
# NEXT_PUBLIC_SUPABASE_ANON_KEY = clave anon / publishable / pública — nunca la secret ni service_role.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
